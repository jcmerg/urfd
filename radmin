#!/bin/bash
#
# radmin - URF Reflector Administration
#
# Auto-detects deployment mode (Docker or systemd) and provides
# matching admin operations: status, restart, logs, config check, reload.
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
OPT_DIR="/opt/urfd"
CONTAINER="urfd"
URFSERV="/etc/systemd/system/urfd.service"
TCDSERV="/etc/systemd/system/tcd.service"

# Colors
RED='\033[0;31m'
GRN='\033[0;32m'
YEL='\033[0;33m'
CYN='\033[0;36m'
RST='\033[0m'

# ---------- deployment detection ----------

detect_mode() {
	if docker ps -q -f name="$CONTAINER" 2>/dev/null | grep -q .; then
		MODE="docker-running"
	elif docker ps -aq -f name="$CONTAINER" 2>/dev/null | grep -q .; then
		MODE="docker-stopped"
	elif [ -e "$URFSERV" ]; then
		MODE="systemd"
	else
		MODE="none"
	fi
}

# ---------- find ini file ----------

find_ini() {
	if [ -n "${1:-}" ] && [ -e "$1" ]; then
		INI="$1"
	elif [ -e "$OPT_DIR/config/urfd.ini" ]; then
		INI="$OPT_DIR/config/urfd.ini"
	elif [ -e "$SCRIPT_DIR/reflector/urfd.ini" ]; then
		INI="$SCRIPT_DIR/reflector/urfd.ini"
	elif [ -e "$SCRIPT_DIR/config/urfd.ini" ]; then
		INI="$SCRIPT_DIR/config/urfd.ini"
	else
		INI=""
	fi
}

# ---------- find inicheck binary ----------

find_inicheck() {
	if [ -x "$SCRIPT_DIR/reflector/inicheck" ]; then
		INICHECK="$SCRIPT_DIR/reflector/inicheck"
	elif command -v inicheck &>/dev/null; then
		INICHECK="inicheck"
	else
		INICHECK=""
	fi
}

# ---------- status ----------

show_status() {
	echo -e "\n${CYN}=== Deployment ===${RST}"
	case "$MODE" in
		docker-running)
			echo -e "Mode: ${GRN}Docker (running)${RST}"
			docker ps -f name="$CONTAINER" --format "table {{.Names}}\t{{.Status}}\t{{.Image}}"
			;;
		docker-stopped)
			echo -e "Mode: ${YEL}Docker (stopped)${RST}"
			docker ps -a -f name="$CONTAINER" --format "table {{.Names}}\t{{.Status}}\t{{.Image}}"
			;;
		systemd)
			echo -e "Mode: ${GRN}systemd${RST}"
			systemctl status urfd --no-pager 2>/dev/null || true
			if [ -e "$TCDSERV" ]; then
				echo ""
				systemctl status tcd --no-pager 2>/dev/null || true
			fi
			;;
		none)
			echo -e "Mode: ${RED}not installed${RST}"
			;;
	esac

	if [ -n "$INI" ]; then
		echo -e "\nINI: $INI"
		local cs
		cs=$(awk '$1 == "Callsign" {print $3; exit}' "$INI" 2>/dev/null || echo "?")
		echo "Callsign: $cs"
	fi

	echo -e "\n${CYN}=== Git ===${RST}"
	git -C "$SCRIPT_DIR" log --oneline -3 2>/dev/null || echo "(not a git repo)"
}

# ---------- actions ----------

do_restart() {
	case "$MODE" in
		docker-running|docker-stopped)
			echo "Restarting Docker container..."
			cd "$OPT_DIR"
			docker compose down
			docker compose up -d
			echo -e "${GRN}Container restarted.${RST}"
			docker ps -f name="$CONTAINER"
			;;
		systemd)
			echo "Restarting urfd service..."
			sudo systemctl restart urfd
			if [ -e "$TCDSERV" ]; then
				sudo systemctl restart tcd
			fi
			echo -e "${GRN}Services restarted.${RST}"
			;;
		*) echo -e "${RED}Nothing to restart.${RST}" ;;
	esac
}

do_stop() {
	case "$MODE" in
		docker-running)
			echo "Stopping container..."
			cd "$OPT_DIR"
			docker compose down
			echo -e "${GRN}Container stopped.${RST}"
			;;
		systemd)
			echo "Stopping services..."
			sudo systemctl stop urfd
			if [ -e "$TCDSERV" ]; then
				sudo systemctl stop tcd
			fi
			echo -e "${GRN}Services stopped.${RST}"
			;;
		*) echo -e "${YEL}Nothing running.${RST}" ;;
	esac
}

do_start() {
	case "$MODE" in
		docker-stopped)
			echo "Starting container..."
			cd "$OPT_DIR"
			docker compose up -d
			echo -e "${GRN}Container started.${RST}"
			docker ps -f name="$CONTAINER"
			;;
		docker-running)
			echo -e "${YEL}Container already running.${RST}"
			;;
		systemd)
			echo "Starting services..."
			if [ -e "$TCDSERV" ]; then
				sudo systemctl start tcd
			fi
			sudo systemctl start urfd
			echo -e "${GRN}Services started.${RST}"
			;;
		*) echo -e "${RED}Not installed.${RST}" ;;
	esac
}

do_logs() {
	local svc="${1:-urfd}"
	case "$MODE" in
		docker-running|docker-stopped)
			docker logs -f "$CONTAINER" 2>&1
			;;
		systemd)
			if [ "$svc" = "tcd" ] && [ -e "$TCDSERV" ]; then
				sudo journalctl -u tcd -f
			else
				sudo journalctl -u urfd -f
			fi
			;;
		*) echo -e "${RED}Nothing to show.${RST}" ;;
	esac
}

do_reload() {
	case "$MODE" in
		docker-running)
			echo "Sending SIGHUP to urfd in container..."
			docker exec "$CONTAINER" kill -HUP "$(docker exec "$CONTAINER" pgrep urfd)"
			echo -e "${GRN}SIGHUP sent. Config reloaded.${RST}"
			;;
		systemd)
			echo "Sending SIGHUP to urfd..."
			sudo kill -HUP "$(pgrep urfd)"
			echo -e "${GRN}SIGHUP sent. Config reloaded.${RST}"
			;;
		*) echo -e "${RED}urfd not running.${RST}" ;;
	esac
}

do_inicheck() {
	local flag="${1:--q}"
	if [ -z "$INICHECK" ]; then
		echo -e "${RED}inicheck binary not found. Build with: cd reflector && make inicheck${RST}"
		return 1
	fi
	if [ -z "$INI" ]; then
		echo -e "${RED}No urfd.ini found.${RST}"
		return 1
	fi
	echo "Running: $INICHECK $flag $INI"
	echo ""
	"$INICHECK" "$flag" "$INI" && echo -e "\n${GRN}OK - no errors.${RST}" || echo -e "\n${RED}Errors found (see above).${RST}"
}

do_build() {
	if [ -x "$OPT_DIR/build.sh" ]; then
		echo "Running $OPT_DIR/build.sh ..."
		"$OPT_DIR/build.sh"
	elif [ -f "$SCRIPT_DIR/reflector/Makefile" ]; then
		echo "Building from source..."
		make -C "$SCRIPT_DIR/reflector" clean all
	else
		echo -e "${RED}No build method found.${RST}"
	fi
}

# ---------- menu ----------

show_menu() {
	echo -e "\n${CYN}=== URF Reflector Admin ===${RST}\n"

	case "$MODE" in
		docker-running)
			echo "  rs  Restart container"
			echo "  st  Stop container"
			echo "  rl  Reload config (SIGHUP)"
			echo "  lo  View logs (Ctrl-C to exit)"
			;;
		docker-stopped)
			echo "  up  Start container"
			echo "  rs  Restart container"
			;;
		systemd)
			echo "  rs  Restart urfd" && [ -e "$TCDSERV" ] && echo "      (includes tcd)"
			echo "  st  Stop urfd"
			echo "  up  Start urfd"
			echo "  rl  Reload config (SIGHUP)"
			echo "  lo  View urfd log"
			[ -e "$TCDSERV" ] && echo "  tl  View tcd log"
			;;
		none)
			echo -e "  ${YEL}(no running deployment detected)${RST}"
			;;
	esac

	echo ""
	echo "  ic  Run inicheck (quiet)"
	echo "  iv  Run inicheck (verbose)"
	echo "  bu  Build"
	echo "  ss  Show status"
	echo ""
	echo "  q   Quit"
	echo ""
}

# ---------- main ----------

find_ini "${1:-}"
find_inicheck
detect_mode

# non-interactive: single command
if [ $# -ge 1 ] && [[ "$1" != *.ini ]]; then
	case "$1" in
		rs|restart)  do_restart ;;
		st|stop)     do_stop ;;
		up|start)    do_start ;;
		lo|logs)     do_logs "${2:-urfd}" ;;
		tl)          do_logs tcd ;;
		rl|reload)   do_reload ;;
		ic|check)    do_inicheck -q ;;
		iv)          do_inicheck -n ;;
		bu|build)    do_build ;;
		ss|status)   show_status ;;
		*)
			echo "Usage: $0 [command] [urfd.ini]"
			echo "Commands: restart|stop|start|logs|reload|check|build|status"
			echo "Interactive mode: $0 [urfd.ini]"
			exit 1
			;;
	esac
	exit 0
fi

# interactive menu loop
key=""
while [[ "$key" != q* ]]; do
	detect_mode
	show_status
	show_menu
	read -rp "Command: " key args

	case "$key" in
		rs*) do_restart ;;
		st*) do_stop ;;
		up*) do_start ;;
		lo*) do_logs "${args:-urfd}" ;;
		tl*) do_logs tcd ;;
		rl*) do_reload ;;
		ic*) do_inicheck -q ;;
		iv*) do_inicheck -n ;;
		bu*) do_build ;;
		ss*) show_status; read -rp "Press Enter..." ;;
		q*)  ;;
		"")  ;;
		*)   echo -e "${YEL}Unknown command: $key${RST}"; sleep 1 ;;
	esac
done
