##############################################################################
#  URFD Whitelist
#
#  One callsign per line. Whitelisted callsigns are explicitly authorized.
#  Supports wildcard (*) as the last character.
#  An empty file means everyone is authorized (default).
#
#  Examples:
#    DL*     authorize all callsigns starting with DL
#    DL4JC   authorize DL4JC exactly
#
##############################################################################
